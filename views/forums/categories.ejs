<%- include('../layout', { body: `
<div class="page-header">
  <div>
    <h1>Forums</h1>
    <p>Browse categories and join the conversations.</p>
  </div>
</div>

${currentUser ? `
  <div class="section-card category-proposal-card">
    <h2>Create a Category</h2>
    <p class="text-muted">Start a new topic area for the community. Keep names clear and specific.</p>
    <form method="POST" action="/forums/categories/create" class="settings-form">
      <div class="form-group">
        <label for="cat-name">Name</label>
        <input id="cat-name" type="text" name="name" required minlength="3" maxlength="60" placeholder="e.g., Database Design">
      </div>
      <div class="form-group">
        <label for="cat-description">Description</label>
        <input id="cat-description" type="text" name="description" maxlength="180" placeholder="What should be discussed in this category?">
      </div>
      <div class="form-group">
        <label for="cat-parent">Parent Category (optional)</label>
        <select id="cat-parent" name="parent_id">
          <option value="">None (top-level)</option>
          ${categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Create Category</button>
    </form>
  </div>
` : ''}

<div class="categories-page">
  ${categories.length === 0 ? `
    <div class="empty-state-large">
      <h2>No categories yet</h2>
      <p>Please check back soon.</p>
    </div>
  ` : categories.map(cat => `
    <div class="category-section">
      <div class="category-section-header">
        <div class="category-icon-large">${(cat.icon && cat.icon.trim()) ? cat.icon.trim() : cat.name.charAt(0).toUpperCase()}</div>
        <div>
          <h2><a href="/forums/category/${cat.id}">${cat.name}</a></h2>
          ${cat.description ? `<p>${cat.description}</p>` : ''}
        </div>
      </div>

      ${cat.subcategories && cat.subcategories.length > 0 ? `
        <div class="subcategory-list">
          ${cat.subcategories.map(sub => `
            <a href="/forums/category/${sub.id}" class="subcategory-item">
              <span class="subcategory-icon">${(sub.icon && sub.icon.trim()) ? sub.icon.trim() : sub.name.charAt(0).toUpperCase()}</span>
              <span class="subcategory-info">
                <strong>${sub.name}</strong>
                ${sub.description ? `<span>${sub.description}</span>` : ''}
              </span>
              <span class="subcategory-stats">
                <span>${sub.thread_count || 0} threads</span>
                <span>${sub.post_count || 0} posts</span>
              </span>
            </a>
          `).join('')}
        </div>
      ` : ''}

      <div class="category-section-footer">
        <span>${cat.thread_count || 0} threads · ${cat.post_count || 0} posts</span>
        <span class="latest-info">
          ${cat.latest_thread_id ? `
            Latest: <a href="/forums/thread/${cat.latest_thread_id}">${cat.latest_thread_title}</a>
            ${cat.latest_poster ? `by ${cat.latest_poster}` : ''}
          ` : 'No threads yet'}
        </span>
      </div>
    </div>
  `).join('')}
</div>
` }) %>
