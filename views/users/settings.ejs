<%- include('../layout', { body: `
<div class="page-header">
  <h1>Account Settings</h1>
</div>

${error ? `<div class="alert alert-error">${error}</div>` : ''}
${success ? `<div class="alert alert-success">${success}</div>` : ''}

<div class="settings-grid">
  <div class="section-card">
    <h2>Profile Settings</h2>
    <form method="POST" action="/users/settings" class="settings-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" value="${currentUser.username}" disabled class="input-disabled">
        <div class="form-help">Username cannot be changed.</div>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="text" value="${currentUser.email}" disabled class="input-disabled">
      </div>
      <div class="form-group">
        <label>Trust Level</label>
        <input type="text" value="${(currentUser.trust_level || 'new').toUpperCase()} (${currentUser.trust_score || 0})" disabled class="input-disabled">
        <div class="form-help">Trust score unlocks stronger community permissions over time.</div>
      </div>
      <div class="form-group">
        <label for="avatar">Avatar URL</label>
        <input type="url" id="avatar" name="avatar" value="${currentUser.avatar}"
          placeholder="https://example.com/avatar.jpg">
        <div class="form-help">Enter a URL to an image. Leave default for the built-in avatar.</div>
      </div>
      <div class="form-group">
        <label for="bio">Bio</label>
        <textarea id="bio" name="bio" rows="4" maxlength="500"
          placeholder="Tell us about yourself...">${currentUser.bio || ''}</textarea>
        <div class="form-help">Max 500 characters.</div>
      </div>
      <div class="form-group">
        <label for="selected_rank_title">Displayed Rank Title</label>
        <select id="selected_rank_title" name="selected_rank_title">
          <option value="" ${!currentSelectedRankTitle ? 'selected' : ''}>Auto (highest unlocked)</option>
          ${unlockedRanks.map(r => `
            <option value="${r.title}" ${currentSelectedRankTitle === r.title ? 'selected' : ''}>${r.title}</option>
          `).join('')}
        </select>
        <div class="form-help">Choose any rank you have unlocked.</div>
      </div>
      <button type="submit" class="btn btn-primary">Save Profile</button>
    </form>
  </div>

  <div class="section-card">
    <h2>Change Password</h2>
    <form method="POST" action="/users/settings" class="settings-form">
      <div class="form-group">
        <label for="current_password">Current Password</label>
        <input type="password" id="current_password" name="current_password" required>
      </div>
      <div class="form-group">
        <label for="new_password">New Password</label>
        <input type="password" id="new_password" name="new_password" required minlength="10">
        <div class="form-help">At least 10 chars with uppercase, lowercase, and number.</div>
      </div>
      <div class="form-group">
        <label for="confirm_password">Confirm New Password</label>
        <input type="password" id="confirm_password" name="confirm_password" required>
      </div>
      <button type="submit" class="btn btn-primary">Change Password</button>
    </form>
  </div>

  <div class="section-card">
    <h2>API Keys</h2>
    <p>Generate API keys to access the CommuniForums data export API.</p>
    <form id="api-key-form" class="settings-form">
      <div class="form-group">
        <label for="key-name">Key Name</label>
        <input type="text" id="key-name" placeholder="My API Key" required>
      </div>
      <button type="submit" class="btn btn-primary">Generate Key</button>
    </form>
    <div id="api-key-result" class="mt-2" style="display:none">
      <div class="alert alert-success">
        <strong>Your API Key:</strong>
        <code id="api-key-value" class="api-key-display"></code>
        <p class="mt-1">Save this key now! It cannot be retrieved again.</p>
      </div>
    </div>
  </div>

  <div class="section-card">
    <h2>Two-Factor Authentication (MFA)</h2>
    ${currentUser.mfa_enabled ? `
      <p>MFA is currently <strong>enabled</strong>.</p>
      <form method="POST" action="/users/settings/mfa/disable" class="settings-form">
        <div class="form-group">
          <label for="current_password_for_mfa">Confirm Password to Disable MFA</label>
          <input type="password" id="current_password_for_mfa" name="current_password_for_mfa" required>
        </div>
        <button type="submit" class="btn">Disable MFA</button>
      </form>
    ` : `
      <p>MFA is currently <strong>disabled</strong>.</p>
      <form method="POST" action="/users/settings/mfa/setup" class="settings-form">
        <button type="submit" class="btn btn-primary">Start MFA Setup</button>
      </form>
    `}

    ${mfaSetup ? `
      <div class="alert alert-success mt-2">
        <p><strong>Secret Key:</strong> <code>${mfaSetup.secret}</code></p>
        <p>Manual setup URI:</p>
        <code class="api-key-display">${mfaSetup.uri}</code>
      </div>
      <form method="POST" action="/users/settings/mfa/enable" class="settings-form mt-2">
        <div class="form-group">
          <label for="mfa_token">Enter 6-digit code from your authenticator app</label>
          <input type="text" id="mfa_token" name="mfa_token" required>
        </div>
        <button type="submit" class="btn btn-primary">Enable MFA</button>
      </form>
    ` : ''}

    ${backupCodes && backupCodes.length ? `
      <div class="alert alert-success mt-2">
        <p><strong>Backup Codes</strong> (store these safely):</p>
        <ul>
          ${backupCodes.map(code => `<li><code>${code}</code></li>`).join('')}
        </ul>
      </div>
    ` : ''}
  </div>
</div>
` }) %>
