<header class="site-header">
  <div class="header-inner container">
    <a class="logo" href="/">
      <span class="logo-icon">CF</span>
      <span>CommuniForums</span>
    </a>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle navigation">Menu</button>

    <nav class="main-nav">
      <a class="nav-link" href="/forums">Forums</a>
      <a class="nav-link" href="/users/members">Members</a>
      <a class="nav-link" href="/search">Search</a>

      <% if (currentUser) { %>
        <a class="nav-link" href="/users/saved">Saved</a>
        <a class="nav-link nav-icon-link" id="notif-bell" href="/notifications">
          Notifications
          <% if (unreadNotifications > 0) { %>
            <span class="badge-count" id="notif-count"><%= unreadNotifications %></span>
          <% } %>
        </a>
        <a class="nav-link nav-icon-link" href="/messages">
          Messages
          <% if (unreadMessages > 0) { %>
            <span class="badge-count"><%= unreadMessages %></span>
          <% } %>
        </a>
      <% } else { %>
        <a class="nav-link btn-link" href="/auth/login">Log in</a>
        <a class="nav-link btn-primary-link" href="/auth/register">Register</a>
      <% } %>
    </nav>

    <% if (currentUser) { %>
      <div class="user-menu">
        <button class="user-menu-btn" id="user-menu-toggle" type="button">
          <img src="<%= currentUser.avatar || '/css/default-avatar.svg' %>" alt="" class="user-avatar-small" onerror="this.src='/css/default-avatar.svg'">
          <span><%= currentUser.username %></span>
          <span class="caret">v</span>
        </button>
        <div class="user-dropdown" id="user-dropdown">
          <a href="/users/profile/<%= currentUser.id %>">Profile</a>
          <a href="/users/settings">Settings</a>
          <% if (currentUser.role === 'admin' || currentUser.role === 'moderator') { %>
            <a href="/admin" class="admin-link">Admin</a>
          <% } %>
          <hr>
          <a href="/auth/logout">Log out</a>
        </div>
      </div>
    <% } %>
  </div>
</header>
